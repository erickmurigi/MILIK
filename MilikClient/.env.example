# MILIK Client - local development template
# Copy to .env for development.
# Replace with real production values in your hosting platform env settings.

# API Configuration
VITE_API_URL=http://localhost:8800/api

# Client-side storage encryption key (change in production)
VITE_STORAGE_KEY=replace-with-a-long-random-key-min-32-chars

# Application Configuration
VITE_APP_NAME=MILIK Property Management
VITE_APP_VERSION=1.0.0
VITE_APP_LOGIN_HINT=Use the temporary password sent from MILIK, then choose a new one now.

# Environment
VITE_NODE_ENV=development

# Optional: Analytics & Monitoring
# VITE_ANALYTICS_ID=
# VITE_SENTRY_DSN=
