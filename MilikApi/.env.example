# MILIK API - production environment template
# Copy to .env and fill with your real production values.
# Do not commit the real .env file.

NODE_ENV=production
PORT=8800

# Database
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/Milik?retryWrites=true&w=majority
# Optional direct non-SRV fallback if your host has SRV DNS issues
MONGO_URL_DIRECT=
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8

# Security
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
EMAIL_CONFIG_SECRET=
JSON_BODY_LIMIT=1mb
TRUST_PROXY=1

# Allowed web origins (comma-separated). In production, set only your real frontend origin(s).
ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
ALLOW_LOCALHOST_ORIGINS=false

# Public frontend URLs used in emails and onboarding links
FRONTEND_URL=https://app.example.com
CLIENT_URL=https://app.example.com
CLIENT_BASE_URL=https://app.example.com
APP_BASE_URL=https://app.example.com
PUBLIC_BASE_URL=https://www.example.com

# System admin bootstrap / audit identity
MILIK_ADMIN_NAME=Milik
MILIK_ADMIN_EMAIL=admin@example.com
MILIK_ADMIN_PASSWORD=change-me-now

# Demo workspace
DEMO_COMPANY_ID=

# SMTP / email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM_EMAIL=MILIK <no-reply@example.com>
ONBOARDING_FROM_EMAIL=MILIK <onboarding@example.com>
TRIAL_FROM_EMAIL=MILIK <demo@example.com>
TRIAL_NOTIFICATION_EMAIL=sales@example.com
ONBOARDING_NOTIFICATION_EMAIL=ops@example.com

# Optional integrations (leave blank unless you use them)
MPESA_ENVIRONMENT=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

PESAPAL_ENVIRONMENT=
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=

PAYPAL_ACCESS_TOKEN=
PREFERRED_PAYMENT_METHOD=
